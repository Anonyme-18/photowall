# Copiez ce fichier vers .env.local (jamais commité) :
#   cp .env.example .env.local

# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://votre-projet.supabase.co

# Secret key (sb_secret_...) — anciennement "service_role"
SUPABASE_SERVICE_ROLE_KEY=sb_secret_votre_cle

# Alias accepté :
# SUPABASE_SECRET_KEY=sb_secret_votre_cle

# Code PIN pour accéder à /admin (dashboard)
ADMIN_PIN=00000000
